<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Add Ingredient</title>
</head>
<body>
  <!-- Navigation for managers -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/inventory">Inventory</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main form used by managers to add a new ingredient -->
  <% var messages = typeof errorMessages !== 'undefined' && errorMessages ? errorMessages : []; %>
  <% var formData = typeof formData !== 'undefined' && formData ? formData : {}; %>
  <div class="container mt-4">
    <h2 class="text-center mb-4">Add New Ingredient</h2>
    <% if (messages.length > 0) { %>
      <div class="alert alert-danger">
        <% messages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <form action="/addProduct" method="POST" enctype="multipart/form-data" class="mx-auto" style="max-width: 600px;">

      <div class="mb-3">
        <label for="name" class="form-label">Ingredient Name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= formData.name || '' %>" required>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <label for="quantity" class="form-label">Quantity</label>
          <input type="number" class="form-control" id="quantity" name="quantity" min="0" step="1" value="<%= formData.quantity || '' %>" required>
        </div>
        <div class="col-md-4 mb-3">
          <label for="unit" class="form-label">Unit</label>
          <input type="text" class="form-control" id="unit" name="unit" value="<%= formData.unit || 'kg' %>">
        </div>
        <div class="col-md-4 mb-3">
          <label for="storageLocation" class="form-label">Storage Location</label>
          <input type="text" class="form-control" id="storageLocation" name="storageLocation" value="<%= formData.storageLocation || '' %>" required>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="supplier" class="form-label">Supplier</label>
          <input type="text" class="form-control" id="supplier" name="supplier" value="<%= formData.supplier || 'N/A' %>">
        </div>
        <div class="col-md-6 mb-3">
          <label for="category" class="form-label">Category</label>
          <input type="text" class="form-control" id="category" name="category" value="<%= formData.category || 'General' %>">
        </div>
      </div>

      <div class="mb-3">
        <label for="expiryDate" class="form-label">Expiry Date</label>
        <input type="date" class="form-control" id="expiryDate" name="expiryDate" value="<%= formData.expiryDate || '' %>">
      </div>

      <div class="mb-4">
        <label for="image" class="form-label">Upload Ingredient Image</label>
        <input class="form-control" type="file" id="image" name="image" accept="image/*">
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary">Add Ingredient</button>
      </div>
    </form>
  </div>
</body>
</html>
