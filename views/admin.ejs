<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <section class="hero-section">
            <div class="hero-text">
                <h1>Welcome back, <%= user.fullName %></h1>
                <p>You're signed in as <%= user.role %>. Keep the kitchen's stock on track from here.</p>
                <div class="hero-actions">
                    <!-- Intentionally empty for now - place a new primary action here later -->
                </div>
            </div>
            <div class="hero-collage">
                <img src="/images/apples.png" alt="Apples" class="collage-img collage-img-1">
                <img src="/images/bread.png" alt="Bread" class="collage-img collage-img-2">
                <img src="/images/milk.png" alt="Milk" class="collage-img collage-img-3">
            </div>
        </section>

        <section class="feature-row">
            <div class="feature-card">
                <i class="bi bi-alarm"></i>
                <h3>Expiry alerts</h3>
                <p>Get notified before your food expires.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-search"></i>
                <h3>Quick search</h3>
                <p>Find any ingredient instantly.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-clipboard-check"></i>
                <h3>Inventory Board</h3>
                <p>Search, filter, and manage every ingredient in stock.</p>
            </div>
            <% if (user.role === 'SuperAdmin') { %>
                <a href="/register-manager" class="feature-card" style="text-decoration: none; color: inherit; display: block;">
                    <i class="bi bi-person-plus"></i>
                    <h3>Register Manager</h3>
                    <p>Create a new manager account for the team.</p>
                </a>
            <% } %>
        </section>
    </div>
</body>
</html>
