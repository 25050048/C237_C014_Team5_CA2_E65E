// rizq
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manager Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
</head>
<body class="bg-light">

    <!-- Header: takes the manager back to their homepage -->
    <header class="bg-dark">
        <div class="container d-flex align-items-center justify-content-between py-2">
            <a href="/admin" class="btn btn-outline-light btn-sm">
                &larr; Back to Admin Dashboard
            </a>
            <span class="navbar-brand text-white mb-0">Manager Dashboard</span>
        </div>
    </header>

    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/board">Kitchen Inventory Board</a>
        </div>
    </nav>

    <main class="container py-4">

        <h1>Manager Dashboard</h1>

        <% if (user) { %>
            <div class="row g-3 mb-4">
                <div class="col-md-6 col-lg-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">Total Ingredients Available</h6>
                            <h2><%= totalAvailable %></h2>
                            <small class="text-muted">Excludes expired stock</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="card shadow-sm h-100 border-danger">
                        <div class="card-body">
                            <h6 class="text-muted">Expired Ingredients</h6>
                            <h2><%= expiredCount %></h2>
                            <small class="text-muted">Number of ingredients past expiry date</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="card shadow-sm h-100 border-warning">
                        <div class="card-body">
                            <h6 class="text-muted">Low Stock Ingredients</h6>
                            <h2><%= lowStockCount %></h2>
                            <small class="text-muted">Number of ingredients at/below minimum stock</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts go under the "how much ingredients there are" section above -->
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">Most Used Ingredients</h6>
                            <% if (mostUsedIngredients.length === 0) { %>
                                <p class="mb-0">No usage recorded yet.</p>
                            <% } else { %>
                                <canvas id="mostUsedChart" height="220"></canvas>
                            <% } %>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">Least Used Ingredients</h6>
                            <% if (leastUsedIngredients.length === 0) { %>
                                <p class="mb-0">No usage recorded yet.</p>
                            <% } else { %>
                                <canvas id="leastUsedChart" height="220"></canvas>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12">
                    <div class="card shadow-sm h-100 border-danger">
                        <div class="card-body">
                            <h6 class="text-muted">Food Waste (Expired Ingredients)</h6>
                            <% if (foodWasteItems.length === 0) { %>
                                <p class="mb-0">No food waste right now — nothing has expired.</p>
                            <% } else { %>
                                <canvas id="foodWasteChart" height="220"></canvas>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

    </main>

    <% if (user) { %>
    <script>
        const mostUsedData = <%- JSON.stringify(mostUsedIngredients) %>;
        const leastUsedData = <%- JSON.stringify(leastUsedIngredients) %>;
        const foodWasteData = <%- JSON.stringify(foodWasteItems) %>;

        const pieColors = ['#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f'];

        if (mostUsedData.length > 0) {
            new Chart(document.getElementById('mostUsedChart'), {
                type: 'pie',
                data: {
                    labels: mostUsedData.map(i => i.ingredientName),
                    datasets: [{
                        data: mostUsedData.map(i => i.totalUsed),
                        backgroundColor: pieColors
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        if (leastUsedData.length > 0) {
            new Chart(document.getElementById('leastUsedChart'), {
                type: 'pie',
                data: {
                    labels: leastUsedData.map(i => i.ingredientName),
                    datasets: [{
                        data: leastUsedData.map(i => i.totalUsed),
                        backgroundColor: pieColors
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        if (foodWasteData.length > 0) {
            new Chart(document.getElementById('foodWasteChart'), {
                type: 'bar',
                data: {
                    labels: foodWasteData.map(i => i.ingredientName),
                    datasets: [{
                        label: 'Wasted quantity',
                        data: foodWasteData.map(i => i.quantity),
                        backgroundColor: '#e15759'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: { display: true, text: 'Quantity (weight/liters)' }
                        }
                    }
                }
            });
        }
    </script>
    <% } %>

</body>
</html>
