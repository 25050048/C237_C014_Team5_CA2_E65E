// rizq
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Inventory Board</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/board">Kitchen Inventory Board</a>
        </div>
    </nav>

    <main class="container py-4">

        <h1>Inventory Board</h1>
        <p class="text-muted mb-4">Ingredients grouped by expiry status, most urgent first within each group.</p>

        <div class="card shadow-sm mb-4 border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Good</h4>
            </div>
            <div class="card-body">
                <% if (goodItems.length === 0) { %>
                    <p class="mb-0">None.</p>
                <% } else { %>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Unit</th>
                                <th>Supplier</th>
                                <th>Storage Location</th>
                                <th>Expiry Date</th>
                                <th>Minimum Stock</th>
                                <th>Days Until Expiry</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% goodItems.forEach(function(item) { %>
                                <tr>
                                    <td><%= item.ingredientName %></td>
                                    <td><%= item.category %></td>
                                    <td><%= item.quantity %></td>
                                    <td><%= item.unit %></td>
                                    <td><%= item.supplier %></td>
                                    <td><%= item.storageLocation %></td>
                                    <td><%= item.expiryDate %></td>
                                    <td><%= item.minimumStock %></td>
                                    <td><%= item.daysUntilExpiry %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>

        <div class="card shadow-sm mb-4 border-warning">
            <div class="card-header bg-warning">
                <h4 class="mb-0">Close to Expiry (within 7 days)</h4>
            </div>
            <div class="card-body">
                <% if (nearExpiryItems.length === 0) { %>
                    <p class="mb-0">None.</p>
                <% } else { %>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Unit</th>
                                <th>Supplier</th>
                                <th>Storage Location</th>
                                <th>Expiry Date</th>
                                <th>Minimum Stock</th>
                                <th>Days Until Expiry</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% nearExpiryItems.forEach(function(item) { %>
                                <tr>
                                    <td><%= item.ingredientName %></td>
                                    <td><%= item.category %></td>
                                    <td><%= item.quantity %></td>
                                    <td><%= item.unit %></td>
                                    <td><%= item.supplier %></td>
                                    <td><%= item.storageLocation %></td>
                                    <td><%= item.expiryDate %></td>
                                    <td><%= item.minimumStock %></td>
                                    <td><%= item.daysUntilExpiry %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>

        <div class="card shadow-sm mb-4 border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Expired</h4>
            </div>
            <div class="card-body">
                <% if (expiredItems.length === 0) { %>
                    <p class="mb-0">None.</p>
                <% } else { %>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Unit</th>
                                <th>Supplier</th>
                                <th>Storage Location</th>
                                <th>Expiry Date</th>
                                <th>Minimum Stock</th>
                                <th>Days Until Expiry</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% expiredItems.forEach(function(item) { %>
                                <tr>
                                    <td><%= item.ingredientName %></td>
                                    <td><%= item.category %></td>
                                    <td><%= item.quantity %></td>
                                    <td><%= item.unit %></td>
                                    <td><%= item.supplier %></td>
                                    <td><%= item.storageLocation %></td>
                                    <td><%= item.expiryDate %></td>
                                    <td><%= item.minimumStock %></td>
                                    <td><%= item.daysUntilExpiry %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>

    </main>

</body>
</html>
