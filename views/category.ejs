<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">

    <%- include('partials/navbar') %>

    <main class="container py-4">

        <% if (typeof successMessages !== 'undefined' && successMessages && successMessages.length) { %>
            <% successMessages.forEach(message => { %>
                <div class="alert alert-success"><%= message %></div>
            <% }) %>
        <% } %>

        <% if (typeof messages !== 'undefined' && messages && messages.length) { %>
            <% messages.forEach(message => { %>
                <div class="alert alert-danger"><%= message %></div>
            <% }) %>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Category Management</h1>
            <a href="/categories/new" class="btn btn-success">+ Add Category</a>
        </div>

        <div class="card">
            <div class="card-body p-0">
                <% if (categories.length === 0) { %>
                    <p class="text-muted p-3 mb-0">No categories yet. Add one to get started.</p>
                <% } else { %>
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% categories.forEach(function(cat) { %>
                                <tr>
                                    <td><%= cat.categoryName %></td>
                                    <td class="text-end">
                                        <a href="/categories/<%= cat.categoryId %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <a href="/categories/<%= cat.categoryId %>/delete" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>

    </main>

</body>
</html>
