<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Kitchen Dashboard</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>

<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                Kitchen Inventory System
            </a>
        </div>
    </nav>

    <main class="container py-4">

        <h1>Kitchen Dashboard</h1>

        <p class="text-muted mb-4">
            Monitor ingredient stock levels and expiry dates.
        </p>

        <div class="row g-3 mb-5">

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Total Ingredients</h6>
                        <h2><%= totalIngredients %></h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm h-100 border-warning">
                    <div class="card-body">
                        <h6 class="text-muted">Low Stock</h6>
                        <h2 class="text-warning"><%= lowStockCount %></h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm h-100 border-danger">
                    <div class="card-body">
                        <h6 class="text-muted">Expired</h6>
                        <h2 class="text-danger"><%= expiredCount %></h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-body">
                        <h6 class="text-muted">Expiring Soon</h6>
                        <h2 class="text-primary"><%= expiringSoonCount %></h2>
                    </div>
                </div>
            </div>

        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h4 class="mb-0">Low-Stock Ingredients</h4>
            </div>

            <div class="card-body">

                <% if (lowStockIngredients.length === 0) { %>

                    <p class="mb-0">No low-stock ingredients.</p>

                <% } else { %>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Ingredient</th>
                                <th>Quantity</th>
                                <th>Minimum Stock</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% lowStockIngredients.forEach((ingredient) => { %>
                                <tr>
                                    <td><%= ingredient.ingredientName %></td>

                                    <td>
                                        <%= ingredient.quantity %>
                                        <%= ingredient.unit || '' %>
                                    </td>

                                    <td>
                                        <%= ingredient.minimumStock %>
                                        <%= ingredient.unit || '' %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                <% } %>

            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h4 class="mb-0">Expired Ingredients</h4>
            </div>

            <div class="card-body">

                <% if (expiredIngredients.length === 0) { %>

                    <p class="mb-0">No expired ingredients.</p>

                <% } else { %>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Ingredient</th>
                                <th>Expiry Date</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% expiredIngredients.forEach((ingredient) => { %>
                                <tr>
                                    <td><%= ingredient.ingredientName %></td>

                                    <td>
                                        <%= new Date(
                                            ingredient.expiryDate
                                        ).toLocaleDateString('en-SG') %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                <% } %>

            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h4 class="mb-0">Expiring Within 7 Days</h4>
            </div>

            <div class="card-body">

                <% if (expiringSoonIngredients.length === 0) { %>

                    <p class="mb-0">No ingredients are expiring soon.</p>

                <% } else { %>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Ingredient</th>
                                <th>Expiry Date</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% expiringSoonIngredients.forEach((ingredient) => { %>
                                <tr>
                                    <td><%= ingredient.ingredientName %></td>

                                    <td>
                                        <%= new Date(
                                            ingredient.expiryDate
                                        ).toLocaleDateString('en-SG') %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                <% } %>

            </div>
        </div>

    </main>

</body>
</html>