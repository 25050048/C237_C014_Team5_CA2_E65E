<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <title>Delete Ingredient</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/manage-inventory">Manage Inventory</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card border-danger shadow-sm">
          <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Confirm Delete Ingredient</h3>
          </div>
          <div class="card-body">
            <% var messages = typeof messages !== 'undefined' && messages ? messages : []; %>
            <% if (messages.length > 0) { %>
              <div class="alert alert-danger">
                <% messages.forEach(function(message) { %>
                  <p class="mb-1"><%= message %></p>
                <% }); %>
              </div>
            <% } %>

            <% if (ingredient) { %>
              <p class="lead">Are you sure you want to delete the ingredient <strong><%= ingredient.ingredientName %></strong>?</p>
              <div class="text-center mb-4">
                <img src="/images/<%= ingredient.image || 'tomatoes.png' %>" alt="<%= ingredient.ingredientName %>" class="img-fluid rounded" style="max-height: 220px; object-fit: contain;">
              </div>
              <div class="text-center mb-4">
                <p class="mb-1"><strong>Category:</strong> <%= ingredient.category || 'N/A' %></p>
                <p class="mb-1"><strong>Quantity:</strong> <%= ingredient.quantity %> <%= ingredient.unit || '' %></p>
                <p class="mb-1"><strong>Storage:</strong> <%= ingredient.storageLocation || 'N/A' %></p>
                <p class="mb-1"><strong>Expiry Date:</strong> <%= ingredient.expiryDate ? new Date(ingredient.expiryDate).toLocaleDateString() : 'Not set' %></p>
              </div>

              <form action="/deleteOldIngredient/<%= ingredient.ingredientId %>" method="POST">
                <div class="d-flex justify-content-between">
                  <a href="/manage-inventory" class="btn btn-outline-secondary">Cancel</a>
                  <button type="submit" class="btn btn-danger">Delete Ingredient</button>
                </div>
              </form>
            <% } else { %>
              <div class="alert alert-warning">Ingredient not found.</div>
              <a href="/manage-inventory" class="btn btn-primary">Back to Inventory</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
