<%# Expiring Soon page (Tara) %>

<%- include('partials/header') %>

<div class="container">

  <h1>Items Expiring Soon</h1>
  <p>Items expiring within the next 3 days, or already expired.</p>
  
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-light">

    <%- include('partials/navbar') %>
</head>

<body class="bg-light">

    <%- include('partials/navbar') %>
  <%# Results %>
  <table class="pantry-table">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Category</th>
        <th>Storage</th>
        <th>Quantity</th>
        <th>Expiry Date</th>
        <th>Days Remaining</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (items.length === 0) { %>
        <tr>
          <td colspan="7">No items expiring soon. Nice work!</td>
        </tr>
      <% } else { %>
        <% items.forEach(function(item) { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.category_name %></td>
            <td><%= item.storage %></td>
            <td><%= item.quantity %></td>
            <td><%= item.expiry_date %></td>
            <td><%= item.days_remaining %></td>
            <td>
              <% if (item.days_remaining < 0) { %>
                <span class="badge badge-expired">🔴 Expired</span>
              <% } else { %>
                <span class="badge badge-soon">🟡 Expiring Soon</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>

</div>

<%- include('partials/footer') %>