<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Expiry Monitoring</title>

    
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-light">

    <%- include('partials/navbar') %>
</head>

<body class="bg-light">



    <main class="container py-4">

        <div
            class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4"
        >

            <div>
                <h1 class="mb-1">
                    Expiry Monitoring
                </h1>

                <p class="text-muted mb-0">
                    Check expired, expiring-soon and safe ingredients.
                </p>
            </div>

            <a
                href="/expiryrequests/new"
                class="btn btn-success"
            >
                + New Expiration Stock Request
            </a>

        </div>


        <% if (
            successMessages &&
            successMessages.length > 0
        ) { %>

            <div class="alert alert-success">
                <%= successMessages[0] %>
            </div>

        <% } %>


        <% if (
            errorMessages &&
            errorMessages.length > 0
        ) { %>

            <div class="alert alert-danger">
                <%= errorMessages[0] %>
            </div>

        <% } %>


        <div class="card border-0 shadow-sm mb-4">

            <div class="card-body">

                <form
                    method="GET"
                    action="/expirymonitoring"
                    class="row g-3"
                >

                    <div class="col-md-6">

                        <label
                            for="search"
                            class="form-label"
                        >
                            Search Ingredient
                        </label>

                        <input
                            id="search"
                            type="text"
                            name="search"
                            class="form-control"
                            value="<%= search %>"
                            placeholder="Example: Chicken"
                        >

                    </div>


                    <div class="col-md-4">

                        <label
                            for="status"
                            class="form-label"
                        >
                            Expiry Status
                        </label>

                        <select
                            id="status"
                            name="status"
                            class="form-select"
                        >

                            <option
                                value="all"
                                <%= selectedStatus === 'all'
                                    ? 'selected'
                                    : '' %>
                            >
                                All Ingredients
                            </option>

                            <option
                                value="expired"
                                <%= selectedStatus === 'expired'
                                    ? 'selected'
                                    : '' %>
                            >
                                Expired
                            </option>

                            <option
                                value="soon"
                                <%= selectedStatus === 'soon'
                                    ? 'selected'
                                    : '' %>
                            >
                                Expiring Within 7 Days
                            </option>

                            <option
                                value="safe"
                                <%= selectedStatus === 'safe'
                                    ? 'selected'
                                    : '' %>
                            >
                                Safe
                            </option>

                        </select>

                    </div>


                    <div class="col-md-2 d-flex align-items-end">

                        <button
                            class="btn btn-dark w-100"
                            type="submit"
                        >
                            Filter
                        </button>

                    </div>

                </form>

            </div>

        </div>


        <div class="card border-0 shadow-sm">

            <div class="card-body p-0">

                <% if (items.length === 0) { %>

                    <p class="p-4 mb-0 text-muted">
                        No ingredients match the selected filters.
                    </p>

                <% } else { %>

                    <div class="table-responsive">

                        <table
                            class="table table-hover align-middle mb-0"
                        >

                            <thead class="table-light">

                                <tr>
                                    <th>Ingredient</th>
                                    <th>Quantity</th>
                                    <th>Minimum Stock</th>
                                    <th>Expiry Date</th>
                                    <th>Time Remaining</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>

                            </thead>


                            <tbody>

                                <% items.forEach(function (item) { %>

                                    <tr>

                                        <td class="fw-semibold">
                                            <%= item.ingredientName %>
                                        </td>

                                        <td>
                                            <%= item.quantity %>
                                            <%= item.unit || '' %>
                                        </td>

                                        <td>
                                            <%= item.minimumStock %>
                                            <%= item.unit || '' %>
                                        </td>

                                        <td>
                                            <%= new Date(
                                                item.expiryDate
                                            ).toLocaleDateString(
                                                'en-SG'
                                            ) %>
                                        </td>

                                        <td>

                                            <% if (
                                                item.daysRemaining < 0
                                            ) { %>

                                                <%= Math.abs(
                                                    item.daysRemaining
                                                ) %>
                                                day(s) overdue

                                            <% } else { %>

                                                <%= item.daysRemaining %>
                                                day(s)

                                            <% } %>

                                        </td>

                                        <td>

                                            <% if (
                                                item.expiryStatus ===
                                                'Expired'
                                            ) { %>

                                                <span
                                                    class="badge text-bg-danger"
                                                >
                                                    Expired
                                                </span>

                                            <% } else if (
                                                item.expiryStatus ===
                                                'Expiring Soon'
                                            ) { %>

                                                <span
                                                    class="badge text-bg-warning"
                                                >
                                                    Expiring Soon
                                                </span>

                                            <% } else { %>

                                                <span
                                                    class="badge text-bg-success"
                                                >
                                                    Safe
                                                </span>

                                            <% } %>

                                        </td>

                                        <td>

                                            <% if (
                                                item.expiryStatus !==
                                                'Safe'
                                            ) { %>

                                                <a
                                                    href="/expiryrequests/new"
                                                    class="btn btn-sm btn-outline-dark"
                                                >
                                                    Request Stock
                                                </a>

                                            <% } else { %>

                                                <span class="text-muted">
                                                    No action needed
                                                </span>

                                            <% } %>

                                        </td>

                                    </tr>

                                <% }); %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </div>

        </div>

    </main>

</body>

</html>