<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Expiration Stock Requests</title>

    
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-light">

    <%- include('partials/navbar') %>
</head>

<body class="bg-light">



    <main class="container py-4">

        <div
            class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4"
        >

            <div>

                <h1 class="mb-1">
                    Expiration Stock Requests
                </h1>

                <p class="text-muted mb-0">
                    Request replacement stock for expired or
                    soon-to-expire ingredients.
                </p>

            </div>

            <a
                href="/expiryrequests/new"
                class="btn btn-success"
            >
                + New Request
            </a>

        </div>


        <% if (
            successMessages &&
            successMessages.length > 0
        ) { %>

            <div class="alert alert-success">
                <%= successMessages[0] %>
            </div>

        <% } %>


        <% if (
            errorMessages &&
            errorMessages.length > 0
        ) { %>

            <div class="alert alert-danger">
                <%= errorMessages[0] %>
            </div>

        <% } %>


        <div class="card border-0 shadow-sm">

            <div class="card-body p-0">

                <% if (requests.length === 0) { %>

                    <p class="p-4 mb-0 text-muted">
                        No expiration stock requests have been submitted.
                    </p>

                <% } else { %>

                    <div class="table-responsive">

                        <table
                            class="table table-hover align-middle mb-0"
                        >

                            <thead class="table-light">

                                <tr>
                                    <th>ID</th>
                                    <th>Ingredient</th>
                                    <th>Request Type</th>
                                    <th>Quantity</th>
                                    <th>Priority</th>
                                    <th>Requested By</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>

                            </thead>


                            <tbody>

                                <% requests.forEach(
                                    function (request) {
                                %>

                                    <tr>

                                        <td>
                                            #<%= request.requestId %>
                                        </td>

                                        <td class="fw-semibold">
                                            <%= request.ingredientName %>
                                        </td>

                                        <td>
                                            <%= request.requestType %>
                                        </td>

                                        <td>
                                            <%= request.requestedQuantity %>
                                            <%= request.unit || '' %>
                                        </td>

                                        <td>

                                            <% if (
                                                request.priority ===
                                                'Urgent'
                                            ) { %>

                                                <span
                                                    class="badge text-bg-danger"
                                                >
                                                    Urgent
                                                </span>

                                            <% } else if (
                                                request.priority ===
                                                'High'
                                            ) { %>

                                                <span
                                                    class="badge text-bg-warning"
                                                >
                                                    High
                                                </span>

                                            <% } else { %>

                                                <span
                                                    class="badge text-bg-secondary"
                                                >
                                                    Normal
                                                </span>

                                            <% } %>

                                        </td>

                                        <td>
                                            <%= request.requestedBy %>
                                        </td>

                                        <td>
                                            <%= new Date(
                                                request.createdAt
                                            ).toLocaleDateString(
                                                'en-SG'
                                            ) %>
                                        </td>

                                        <td>

                                            <span
                                                class="badge text-bg-primary"
                                            >
                                                <%= request.status %>
                                            </span>

                                        </td>

                                    </tr>


                                    <tr class="table-light">

                                        <td></td>

                                        <td colspan="7">

                                            <small>

                                                <strong>
                                                    Reason:
                                                </strong>

                                                <%= request.reason %>

                                            </small>

                                        </td>

                                    </tr>

                                <% }); %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </div>

        </div>

    </main>

</body>

</html>