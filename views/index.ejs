<!DOCTYPE html>
<html>
<head>
    <title>Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success mt-3">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <section class="hero-section">
            <div class="hero-text">
                <h1>Know what's in your pantry. Waste less food.</h1>
                <p>Track ingredients, get notified before things expire, and keep your kitchen running smoothly.</p>
                <% if (typeof user !== 'undefined' && user) { %>
                    <p class="hero-greeting">Welcome back, <%= user.fullname %></p>
                    <div class="hero-actions">
                        <a href="<%= user.role === 'chef' ? '/dashboard' : '/admin' %>" class="btn btn-dark">Go to dashboard</a>
                        <a href="/logout" class="btn btn-outline-dark">Logout</a>
                    </div>
                <% } else { %>
                    <div class="hero-actions">
                        <a href="/register" class="btn btn-dark">Get started</a>
                        <a href="/login" class="btn btn-outline-dark">Log in</a>
                    </div>
                <% } %>
            </div>
            <div class="hero-collage">
                <img src="/images/apples.png" alt="Apples" class="collage-img collage-img-1">
                <img src="/images/bread.png" alt="Bread" class="collage-img collage-img-2">
                <img src="/images/milk.png" alt="Milk" class="collage-img collage-img-3">
            </div>
        </section>

        <section class="feature-row">
            <div class="feature-card">
                <i class="bi bi-alarm"></i>
                <h3>Expiry alerts</h3>
                <p>Get notified before your food expires.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-search"></i>
                <h3>Quick search</h3>
                <p>Find any ingredient instantly.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-clipboard-check"></i>
                <h3>Easy inventory</h3>
                <p>Add and update stock in seconds.</p>
            </div>
        </section>
    </div>
</body>
</html>
