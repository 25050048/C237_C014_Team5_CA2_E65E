<!DOCTYPE html>
<html>
<head>
    <title>Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <% if (messages && messages.length > 0) { %>
          <div class="modal fade" id="loginSuccessModal" tabindex="-1" aria-labelledby="loginSuccessModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content border-success">
                <div class="modal-header bg-success text-white">
                  <h5 class="modal-title" id="loginSuccessModalLabel">Success</h5>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                  <% }); %>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-success" data-bs-dismiss="modal">OK</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section class="hero-section">
            <div class="hero-text">
                <h1>Know what's in your pantry. Waste less food.</h1>
                <p>Track ingredients, get notified before things expire, and keep your kitchen running smoothly.</p>
                <% if (typeof user !== 'undefined' && user) { %>
                    <p class="hero-greeting">Welcome back, <%= user.fullName %></p>
                    <div class="hero-actions">
                        <a href="<%= user.role === 'Chef' ? '/dashboard' : '/admin' %>" class="btn btn-dark">Go to dashboard</a>
                        <a href="/logout" class="btn btn-outline-dark">Logout</a>
                    </div>
                <% } else { %>
                    <div class="hero-actions">
                        <a href="/register" class="btn btn-dark">Get started</a>
                        <a href="/login" class="btn btn-outline-dark">Log in</a>
                    </div>
                <% } %>
            </div>
            <div class="hero-collage">
                <img src="/images/apples.png" alt="Apples" class="collage-img collage-img-1">
                <img src="/images/bread.png" alt="Bread" class="collage-img collage-img-2">
                <img src="/images/milk.png" alt="Milk" class="collage-img collage-img-3">
            </div>
        </section>

        <section class="feature-row">
            <div class="feature-card">
                <i class="bi bi-alarm"></i>
                <h3>Expiry alerts</h3>
                <p>Get notified before your food expires.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-search"></i>
                <h3>Quick search</h3>
                <p>Find any ingredient instantly.</p>
            </div>
            <div class="feature-card">
                <i class="bi bi-clipboard-check"></i>
                <h3>Easy inventory</h3>
                <p>Add and update stock in seconds.</p>
            </div>
        </section>
    </div>
    <% if (messages && messages.length > 0) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          var loginSuccessModalEl = document.getElementById('loginSuccessModal');
          if (loginSuccessModalEl) {
            var loginSuccessModal = new bootstrap.Modal(loginSuccessModalEl);
            loginSuccessModal.show();
          }
        });
      </script>
    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
