<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Ingredient Details</title>
</head>
<body>
    <!-- Navigation depends on the logged-in role -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/">Kitchen Inventory</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav">
              <% if (user.role === 'admin' || user.role === 'manager') { %>
                <li class="nav-item">
                  <a class="nav-link" href="/inventory">Inventory</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/addProduct">Add ingredient</a>
                </li>
              <% } %>
              <li class="nav-item">
                <a class="nav-link" href="/logout">Logout</a>
              </li>
            </ul>
          </div>
        </div>
    </nav>

    <!-- Detailed ingredient information viewed by chefs and managers -->
    <div class="container mt-4">
        <p>Welcome, <%= staff.fullName %> (<%= staff.role %>)</p>
        <h2 class="text-center mb-4">Ingredient Details</h2>
        <% if (ingredient) { %>
            <div class="card mx-auto" style="max-width: 600px;">
                <div class="card-body">
                    <p><b>Ingredient Name:</b><br> <%= ingredient.ingredientName %></p>
                    <p><b>Image:</b><br> <img src="../images/<%= ingredient.image %>" width="20%"></p>
                    <p><b>Category:</b><br> <%= ingredient.category || 'General' %></p>                    
                    <p><b>Quantity:</b><br> <%= ingredient.quantity %> <%= ingredient.unit || 'kg' %></p>
                    <p><b>Storage Location:</b><br> <%= ingredient.storageLocation || 'N/A' %></p>
                    <p><b>Supplier:</b><br> <%= ingredient.supplier || 'N/A' %></p>                    
                    <p><b>Expiry Date:</b><br> <%= ingredient.expiryDate ? new Date(ingredient.expiryDate).toLocaleDateString() : 'Not set' %></p>                    
                </div>
            </div>
        <% } else { %>
            <p>No ingredient found.</p>
        <% } %>
        <div class="text-center mt-3">
          <% if (user.role === 'admin' || user.role === 'manager') { %>
            <a href="/inventory" class="btn btn-secondary">Back</a>
          <% } else { %>
            <a href="/shopping" class="btn btn-secondary">Back</a>
          <% } %>
        </div>
    </div>
</body>
</html>
