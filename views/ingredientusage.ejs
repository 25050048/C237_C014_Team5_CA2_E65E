<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingredient Usage</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">

        <a class="navbar-brand" href="/dashboard">
            Kitchen Inventory System
        </a>

        <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link active" href="/ingredient-usage">
                        Ingredient Usage
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">
                        Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/logout">
                        Logout
                    </a>
                </li>

            </ul>

        </div>

    </div>
</nav>

<div class="container mt-5">

    <h2 class="mb-4">
        Record Ingredient Usage
    </h2>

    <% if(messages && messages.length > 0){ %>

        <div class="alert alert-success">

            <% messages.forEach(function(message){ %>

                <p class="mb-0"><%= message %></p>

            <% }) %>

        </div>

    <% } %>


    <% if(errors && errors.length > 0){ %>

        <div class="alert alert-danger">

            <% errors.forEach(function(error){ %>

                <p class="mb-0"><%= error %></p>

            <% }) %>

        </div>

    <% } %>


    <div class="card shadow">

        <div class="card-body">

            <form action="/ingredient-usage" method="POST">

                <!-- Ingredient -->

                <div class="mb-3">

                    <label class="form-label">

                        Ingredient

                    </label>

                    <select
                        name="ingredientId"
                        class="form-select"
                        required>

                        <option value="">
                            -- Select Ingredient --
                        </option>

                        <% ingredients.forEach(function(item){ %>

                            <option value="<%= item.ingredientId %>">

                                <%= item.ingredientName %>
                                (<%= item.quantity %> <%= item.unit %>)

                            </option>

                        <% }) %>

                    </select>

                </div>


                <!-- Quantity Used -->

                <div class="mb-3">

                    <label class="form-label">

                        Quantity Used

                    </label>

                    <input
                        type="number"
                        name="quantityUsed"
                        class="form-control"
                        min="0.01"
                        step="0.01"
                        required>

                </div>


                <!-- Remarks -->

                <div class="mb-3">

                    <label class="form-label">

                        Remarks

                    </label>

                    <textarea
                        class="form-control"
                        name="remarks"
                        rows="3"
                        placeholder="Example: Lunch Service"
                    ></textarea>

                </div>


                <button
                    type="submit"
                    class="btn btn-success">

                    Record Usage

                </button>

                <a
                    href="/dashboard"
                    class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>