<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Kitchen Inventory Dashboard</title>
</head>
<body>
  <!-- Navigation for managers -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/addProduct">Add Ingredient</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/restocking-requests">Restocking</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/reports">Reports</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main page content for the manager dashboard -->
  <% var messages = typeof messages !== 'undefined' && messages ? messages : []; %>
  <% var successMessages = typeof successMessages !== 'undefined' && successMessages ? successMessages : []; %>
  <div class="container mt-4">
    <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
    <% if (messages.length > 0) { %>
      <div class="alert alert-danger">
        <% messages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <% if (successMessages && successMessages.length > 0) { %>
      <div class="alert alert-success">
        <% successMessages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <h2 class="text-center mb-4">Manager Inventory Dashboard</h2>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-primary">
          <div class="card-body">
            <h6 class="card-title">Total Ingredients</h6>
            <h3><%= stats.totalIngredients %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-warning">
          <div class="card-body">
            <h6 class="card-title">Low Stock Alerts</h6>
            <h3><%= stats.lowStockCount %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-danger">
          <div class="card-body">
            <h6 class="card-title">Expiring Soon</h6>
            <h3><%= stats.expiringSoonCount %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-success">
          <div class="card-body">
            <h6 class="card-title">Most Used</h6>
            <h5><%= stats.mostUsedIngredient %></h5>
          </div>
        </div>
      </div>
    </div>

    <!-- Search and filter controls for inventory records -->
    <form method="GET" class="row g-2 mb-3">
      <div class="col-md-5">
        <input type="text" class="form-control" name="search" placeholder="Search ingredient or supplier" value="<%= search %>">
      </div>
      <div class="col-md-4">
        <select name="category" class="form-control">
          <option value="">All Categories</option>
          <option value="Vegetables" <%= category === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
          <option value="Proteins" <%= category === 'Proteins' ? 'selected' : '' %>>Proteins</option>
          <option value="Grains" <%= category === 'Grains' ? 'selected' : '' %>>Grains</option>
          <option value="Dairy" <%= category === 'Dairy' ? 'selected' : '' %>>Dairy</option>
          <option value="General" <%= category === 'General' ? 'selected' : '' %>>General</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
    </form>

    <% if (products.length === 0) { %>
      <div class="alert alert-info">No ingredients found for the current filter.</div>
    <% } else { %>
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Ingredient</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Unit</th>
            <th>Supplier</th>
            <th>Expiry</th>
            <th>Edit</th>
            <th>Delete</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < products.length; i++) { %>
            <% const isLowStock = products[i].quantity <= 10; %>
            <% const isExpiring = products[i].expiryDate && (new Date(products[i].expiryDate) - new Date()) <= 7 * 24 * 60 * 60 * 1000; %>
            <tr>
              <td>
                <a href="/product/<%= products[i].productId %>"><%= products[i].productName %></a>
                <% if (isLowStock) { %><span class="badge bg-warning text-dark ms-2">Low stock</span><% } %>
                <% if (isExpiring) { %><span class="badge bg-danger ms-2">Expiring</span><% } %>
              </td>
              <td><%= products[i].category %></td>
              <td><%= products[i].quantity %></td>
              <td><%= products[i].unit %></td>
              <td><%= products[i].supplier %></td>
              <td><%= products[i].expiryDate ? new Date(products[i].expiryDate).toLocaleDateString() : 'Not set' %></td>
              <td><a href="/updateProduct/<%= products[i].productId %>">Edit</a></td>
              <td><a href="/deleteProduct/<%= products[i].productId %>" onclick="return confirm('Delete this ingredient record?')">Delete</a></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
