<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Chef Ingredient View</title>
</head>
<body>
  <!-- Navigation for chefs -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main content for chefs -->
  <% var messages = typeof messages !== 'undefined' && messages ? messages : []; %>
  <% var successMessages = typeof successMessages !== 'undefined' && successMessages ? successMessages : []; %>
  <div class="container mt-4">
    <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
    <% if (messages.length > 0) { %>
      <div class="alert alert-danger">
        <% messages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <% if (successMessages && successMessages.length > 0) { %>
      <div class="alert alert-success">
        <% successMessages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <h2 class="text-center mb-3">Available Ingredients for Kitchen Use</h2>
    <p class="text-center text-muted">Search, filter, and record ingredient usage after preparation.</p>

    <% const lowStockItems = products.filter(item => item.quantity <= 10); %>
    <% const expiringItems = products.filter(item => item.expiryDate && (new Date(item.expiryDate) - new Date()) <= 7 * 24 * 60 * 60 * 1000); %>

    <div class="alert alert-warning">
      <strong>Low stock alerts:</strong>
      <% if (lowStockItems.length > 0) { %>
        <span><%= lowStockItems.map(item => item.productName).join(', ') %></span>
      <% } else { %>
        <span>No low stock ingredients at the moment.</span>
      <% } %>
    </div>

    <div class="alert alert-danger">
      <strong>Expiring soon:</strong>
      <% if (expiringItems.length > 0) { %>
        <span><%= expiringItems.map(item => item.productName).join(', ') %></span>
      <% } else { %>
        <span>No ingredients are expiring in the next 7 days.</span>
      <% } %>
    </div>

    <form method="GET" class="row g-2 mb-3">
      <div class="col-md-5">
        <input type="text" class="form-control" name="search" placeholder="Search ingredient" value="<%= search %>">
      </div>
      <div class="col-md-4">
        <select name="category" class="form-control">
          <option value="">All Categories</option>
          <option value="Vegetables" <%= category === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
          <option value="Proteins" <%= category === 'Proteins' ? 'selected' : '' %>>Proteins</option>
          <option value="Grains" <%= category === 'Grains' ? 'selected' : '' %>>Grains</option>
          <option value="Dairy" <%= category === 'Dairy' ? 'selected' : '' %>>Dairy</option>
          <option value="General" <%= category === 'General' ? 'selected' : '' %>>General</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
    </form>

    <% if (products.length === 0) { %>
      <div class="alert alert-info">No ingredients match your search.</div>
    <% } else { %>
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Ingredient</th>
            <th>Category</th>
            <th>Stock</th>
            <th>Unit</th>
            <th>Expiry</th>
            <th>Usage</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < products.length; i++) { %>
            <tr>
              <td>
                <a href="/product/<%= products[i].productId %>"><%= products[i].productName %></a>
              </td>
              <td><%= products[i].category %></td>
              <td><%= products[i].quantity %></td>
              <td><%= products[i].unit %></td>
              <td><%= products[i].expiryDate ? new Date(products[i].expiryDate).toLocaleDateString() : 'Not set' %></td>
              <td>
                <form action="/record-usage/<%= products[i].productId %>" method="POST" class="d-flex gap-2 mb-2">
                  <input type="number" name="usageAmount" class="form-control" min="1" value="1" style="width: 80px;">
                  <button type="submit" class="btn btn-success">Record</button>
                </form>
                <form action="/restocking-request/<%= products[i].productId %>" method="POST" class="d-flex gap-2">
                  <input type="number" name="requestedQty" class="form-control" min="1" value="5" style="width: 80px;">
                  <button type="submit" class="btn btn-warning">Restock</button>
                </form>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
