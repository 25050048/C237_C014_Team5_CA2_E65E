<!DOCTYPE html>
<html>
<head>
    <title>Kitchen Inventory Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
  <!-- Navigation for managers -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/addNewIngredient">Add Ingredient</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/restocking-requests">Restocking</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main page content for the manager dashboard -->
  <% var messages = typeof messages !== 'undefined' && messages ? messages : []; %>
  <% var successMessages = typeof successMessages !== 'undefined' && successMessages ? successMessages : []; %>
  <% var displayIngredients = typeof ingredients !== 'undefined' && ingredients ? ingredients : []; %>
  <div class="container mt-4">
    <p>Welcome, <%= (staff && staff.fullName) || (staff && staff.fullname) || (user && user.fullName) || (user && user.fullname) || '' %> <span class="text-muted">(<%= (staff && staff.role) || (user && user.role) || '' %>)</span></p>
    <% if (messages.length > 0) { %>
      <div class="alert alert-danger">
        <% messages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>
    <% if (successMessages && successMessages.length > 0) { %>
      <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
              <h5 class="modal-title" id="successModalLabel">Success</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <% successMessages.forEach(function(message) { %>
                <p class="mb-1"><%= message %></p>
              <% }); %>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-success" data-bs-dismiss="modal">OK</button>
            </div>
          </div>
        </div>
      </div>
    <% } %>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Manager Inventory Dashboard</h2>
      <a href="/addNewIngredient" class="btn btn-success">Add Ingredient</a>
    </div>

    <% if (successMessages && successMessages.length > 0) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          var successModalEl = document.getElementById('successModal');
          if (successModalEl) {
            var successModal = new bootstrap.Modal(successModalEl);
            successModal.show();
          }
        });
      </script>
    <% } %>


    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-primary">
          <div class="card-body">
            <h6 class="card-title">Total Ingredients</h6>
            <h3><%= stats.totalIngredients %></h3>
          </div>
        </div>
      </div>      
    </div>

    <!-- Search and filter controls for inventory records -->
    <form method="GET" class="row g-2 mb-3">
      <div class="col-md-5">
        <input type="text" class="form-control" name="search" placeholder="Search ingredient or supplier" value="<%= search %>">
      </div>
      <div class="col-md-4">
        <select name="category" class="form-control">
          <option value="" <%= category === '' ? 'selected' : '' %>>All Categories</option>
          <% if (categories && categories.length > 0) { %>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
    </form>

    <% if (displayIngredients.length === 0) { %>
      <div class="alert alert-info">No ingredients found for the current filter.</div>
    <% } else { %>
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Ingredient</th>
            <th>Image</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Unit</th>
            <th>Storage Location</th>
            <th>Supplier</th>
            <th>Expiry Date</th>
            <th>Edit</th>
            <th>Delete</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < displayIngredients.length; i++) { %>
            <% const item = displayIngredients[i]; %>
            <% const isLowStock = item.quantity <= 10; %>
            <% const isExpiring = item.expiryDate && (new Date(item.expiryDate) - new Date()) <= 7 * 24 * 60 * 60 * 1000; %>
            <tr>
              <td><%= item.ingredientName %></td>
              <td>
                <img src="/images/<%= item.image %>" alt="<%= item.ingredientName %>" width="50" onerror="this.onerror=null; this.src='/images/tomatoes.png'">
              </td>
              <td><%= item.category %></td>
              <td><%= item.quantity %></td>
              <td><%= item.unit %></td>
              <td><%= item.storageLocation %></td>
              <td><%= item.supplier %></td>
              <td><%= item.expiryDate ? new Date(item.expiryDate).toLocaleDateString() : 'Not set' %></td>
              <td>
                <a href="#" class="edit-ingredient-link" 
                   data-id="<%= item.ingredientId %>"
                   data-name="<%= item.ingredientName %>"
                   data-category="<%= item.category || '' %>"
                   data-supplier="<%= item.supplier || '' %>"
                   data-quantity="<%= item.quantity %>"
                   data-unit="<%= item.unit || '' %>"
                   data-storage-location="<%= item.storageLocation || '' %>"
                   data-expiry-date="<%= item.expiryDate ? new Date(item.expiryDate).toISOString().slice(0,10) : '' %>"
                   data-image="<%= item.image || '' %>">
                  Edit
                </a>
              </td>
              <td><a href="/deleteIngredient/<%= item.ingredientId %>">Delete</a></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
