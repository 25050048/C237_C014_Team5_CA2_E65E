<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Category</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">

    <%- include('partials/navbar') %>

    <main class="container py-4" style="max-width: 500px;">

        <h1 class="mb-4">Add Category</h1>

        <% if (typeof messages !== 'undefined' && messages && messages.length) { %>
            <% messages.forEach(message => { %>
                <div class="alert alert-danger"><%= message %></div>
            <% }) %>
        <% } %>

        <div class="card">
            <div class="card-body">
                <form method="POST" action="/categories/new">
                    <div class="mb-3">
                        <label for="categoryName" class="form-label">Category Name</label>
                        <input
                            type="text"
                            id="categoryName"
                            name="categoryName"
                            class="form-control"
                            placeholder="Example: Seafood"
                            value="<%= (typeof formData !== 'undefined' && formData.categoryName) ? formData.categoryName : '' %>"
                            maxlength="50"
                            required
                        >
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a href="/categories" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success">Add Category</button>
                    </div>
                </form>
            </div>
        </div>

    </main>

</body>
</html>
