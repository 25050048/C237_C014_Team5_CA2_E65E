<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>New Expiration Stock Request</title>

   
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-light">

    <%- include('partials/navbar') %>
</head>



    <main class="container py-4">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="mb-4">

                    <a
                        href="/expiryrequests"
                        class="text-decoration-none"
                    >
                        ← Back to Expiry Requests
                    </a>

                    <h1 class="mt-3 mb-1">
                        New Expiration Stock Request
                    </h1>

                    <p class="text-muted">
                        Select an expired or soon-to-expire ingredient
                        and request replacement stock.
                    </p>

                </div>


                <% if (
                    errorMessages &&
                    errorMessages.length > 0
                ) { %>

                    <div class="alert alert-danger">
                        <%= errorMessages[0] %>
                    </div>

                <% } %>


                <div class="card border-0 shadow-sm">

                    <div class="card-body p-4">

                        <form
                            method="POST"
                            action="/expiryrequests"
                        >

                            <div class="mb-3">

                                <label
                                    for="ingredientId"
                                    class="form-label"
                                >
                                    Ingredient
                                </label>

                                <select
                                    id="ingredientId"
                                    name="ingredientId"
                                    class="form-select"
                                    required
                                >

                                    <option value="">
                                        Select an ingredient
                                    </option>


                                    <% ingredients.forEach(
                                        function (ingredient) {
                                    %>

                                        <option
                                            value="<%= ingredient.ingredientId %>"
                                        >

                                            <%= ingredient.ingredientName %>

                                            —

                                            <% if (
                                                ingredient.daysRemaining < 0
                                            ) { %>

                                                Expired
                                                <%= Math.abs(
                                                    ingredient.daysRemaining
                                                ) %>
                                                day(s) ago

                                            <% } else { %>

                                                <%= ingredient.daysRemaining %>
                                                day(s) remaining

                                            <% } %>

                                            —

                                            Current stock:
                                            <%= ingredient.quantity %>
                                            <%= ingredient.unit || '' %>

                                        </option>

                                    <% }); %>

                                </select>

                            </div>


                            <div class="mb-3">

                                <label
                                    for="requestType"
                                    class="form-label"
                                >
                                    Request Type
                                </label>

                                <select
                                    id="requestType"
                                    name="requestType"
                                    class="form-select"
                                    required
                                >

                                    <option value="">
                                        Select request type
                                    </option>

                                    <option
                                        value="Replace Expired Stock"
                                    >
                                        Replace Expired Stock
                                    </option>

                                    <option
                                        value="Top Up Expiring Stock"
                                    >
                                        Top Up Expiring Stock
                                    </option>

                                </select>

                            </div>


                            <div class="row g-3">

                                <div class="col-md-6">

                                    <label
                                        for="requestedQuantity"
                                        class="form-label"
                                    >
                                        Requested Quantity
                                    </label>

                                    <input
                                        id="requestedQuantity"
                                        type="number"
                                        name="requestedQuantity"
                                        class="form-control"
                                        min="0.01"
                                        step="0.01"
                                        required
                                    >

                                </div>


                                <div class="col-md-6">

                                    <label
                                        for="priority"
                                        class="form-label"
                                    >
                                        Priority
                                    </label>

                                    <select
                                        id="priority"
                                        name="priority"
                                        class="form-select"
                                        required
                                    >

                                        <option value="Normal">
                                            Normal
                                        </option>

                                        <option value="High">
                                            High
                                        </option>

                                        <option value="Urgent">
                                            Urgent
                                        </option>

                                    </select>

                                </div>

                            </div>


                            <div class="mt-3 mb-4">

                                <label
                                    for="reason"
                                    class="form-label"
                                >
                                    Reason
                                </label>

                                <textarea
                                    id="reason"
                                    name="reason"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Explain why the ingredient needs replacement or additional stock."
                                    required
                                ></textarea>

                            </div>


                            <div class="d-flex gap-2">

                                <button
                                    type="submit"
                                    class="btn btn-success"
                                >
                                    Submit Request
                                </button>

                                <a
                                    href="/expiryrequests"
                                    class="btn btn-outline-secondary"
                                >
                                    Cancel
                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </main>

</body>

</html>