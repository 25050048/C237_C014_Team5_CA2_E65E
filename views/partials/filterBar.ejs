// Search & Filter bar for Pantry
// Submits as a GET request so filters show up in the URL query string

<form action="/pantry" method="GET" class="filter-bar">

  // Search by item name
  <input
    type="text"
    name="search"
    placeholder="Search food item..."
    value="<%= typeof search !== 'undefined' ? search : '' %>"
  >

  // Filter by category
  <select name="category">
    <option value="">All Categories</option>
    <% categories.forEach(function(cat) { %>
      <option value="<%= cat.id %>"
        <%= (typeof selectedCategory !== 'undefined' && selectedCategory == cat.id) ? 'selected' : '' %>>
        <%= cat.name %>
      </option>
    <% }); %>
  </select>

  // Filter by storage location
  <select name="storage">
    <option value="">All Storage</option>
    <option value="pantry"  <%= (typeof selectedStorage !== 'undefined' && selectedStorage === 'pantry')  ? 'selected' : '' %>>Pantry</option>
    <option value="fridge"  <%= (typeof selectedStorage !== 'undefined' && selectedStorage === 'fridge')  ? 'selected' : '' %>>Fridge</option>
    <option value="freezer" <%= (typeof selectedStorage !== 'undefined' && selectedStorage === 'freezer') ? 'selected' : '' %>>Freezer</option>
  </select>

  // Filter by expiry status
  <select name="expiry">
    <option value="">All Items</option>
    <option value="expired" <%= (typeof selectedExpiry !== 'undefined' && selectedExpiry === 'expired') ? 'selected' : '' %>>Expired</option>
    <option value="3days"   <%= (typeof selectedExpiry !== 'undefined' && selectedExpiry === '3days')   ? 'selected' : '' %>>Expiring in 3 Days</option>
    <option value="7days"   <%= (typeof selectedExpiry !== 'undefined' && selectedExpiry === '7days')   ? 'selected' : '' %>>Expiring in 7 Days</option>
  </select>

  // Sort options
  <select name="sort">
    <option value="">Sort By</option>
    <option value="expiry_asc" <%= (typeof selectedSort !== 'undefined' && selectedSort === 'expiry_asc') ? 'selected' : '' %>>Expiry Date (Soonest)</option>
    <option value="expiry_desc" <%= (typeof selectedSort !== 'undefined' && selectedSort === 'expiry_desc') ? 'selected' : '' %>>Expiry Date (Latest)</option>
    <option value="name_asc" <%= (typeof selectedSort !== 'undefined' && selectedSort === 'name_asc') ? 'selected' : '' %>>Name (A-Z)</option>
    <option value="newest" <%= (typeof selectedSort !== 'undefined' && selectedSort === 'newest') ? 'selected' : '' %>>Newest Added</option>
  </select>

  <button type="submit">Apply Filters</button>
  <a href="/pantry" class="clear-filters">Clear</a>

</form>
