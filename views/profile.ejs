<!DOCTYPE html>
<html>
<head>
    <title>My Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="pf-page">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1>My profile</h1>
                <p class="pf-subtitle">View your account details and manage your photo, contact info, and password.</p>
            </div>
            <a href="/logout" class="pf-btn-danger text-nowrap">Logout</a>
        </div>

        <% if (messages && messages.length > 0) { %>
            <div class="pf-alert alert-danger">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>
        <% if (successMessages && successMessages.length > 0) { %>
            <div class="pf-alert alert-success">
                <% successMessages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <!-- Profile picture -->
        <div class="pf-card">
            <h2>Profile picture</h2>
            <p class="pf-card-subtitle">JPG, PNG, or GIF, up to 5MB.</p>
            <div class="pf-avatar-row">
                <% if (profile.profilePicture) { %>
                    <img src="/images/<%= profile.profilePicture %>" alt="Profile picture" class="pf-avatar">
                <% } else { %>
                    <div class="pf-avatar-fallback"><%= profile.fullName.charAt(0).toUpperCase() %></div>
                <% } %>
                <form method="POST" action="/profile/picture" enctype="multipart/form-data" class="d-flex align-items-center gap-2">
                    <input type="file" name="profilePicture" accept="image/png, image/jpeg, image/gif" class="form-control form-control-sm" required style="border-radius: 10px;">
                    <button type="submit" class="pf-btn text-nowrap">Upload</button>
                </form>
            </div>
        </div>

        <!-- Account details -->
        <div class="pf-card">
            <h2>Account details</h2>
            <p class="pf-card-subtitle">Your name, email, and role are managed by your account and can't be changed here.</p>

            <div class="pf-field-label">Full name</div>
            <div class="pf-field-value"><%= profile.fullName %></div>

            <div class="pf-field-label">Email</div>
            <div class="pf-field-value"><%= profile.email %></div>

            <div class="pf-field-label">Role</div>
            <div class="pf-field-value"><%= profile.role %></div>
        </div>

        <!-- Contact info -->
        <div class="pf-card">
            <h2>Contact info</h2>
            <p class="pf-card-subtitle">Optional - phone number and address.</p>
            <form method="POST" action="/profile/contact">
                <div class="pf-form-group">
                    <label for="phone">Phone number</label>
                    <input type="tel" id="phone" name="phone" class="form-control" placeholder="+65 9123 4567" value="<%= profile.phone || '' %>">
                </div>
                <div class="pf-form-group">
                    <label for="address">Address</label>
                    <input type="text" id="address" name="address" class="form-control" placeholder="Street, unit, postal code" value="<%= profile.address || '' %>">
                </div>
                <button type="submit" class="pf-btn">Save contact info</button>
            </form>
        </div>

        <!-- Change password -->
        <div class="pf-card">
            <h2>Change password</h2>
            <p class="pf-card-subtitle">Enter your current password, then your new password twice to confirm it.</p>
            <form method="POST" action="/profile/password">
                <div class="pf-form-group">
                    <label for="currentPassword">Current password</label>
                    <input type="password" id="currentPassword" name="currentPassword" class="form-control" required>
                </div>
                <div class="pf-form-group">
                    <label for="newPassword">New password</label>
                    <input type="password" id="newPassword" name="newPassword" class="form-control" minlength="6" required>
                </div>
                <div class="pf-form-group">
                    <label for="confirmPassword">Confirm new password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" minlength="6" required>
                </div>
                <button type="submit" class="pf-btn">Change password</button>
            </form>
        </div>
    </div>
</body>
</html>
