<%# Pantry Search & Filter page (Tara) %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Ingredients</title>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="container">

    <h1>Search Ingredients</h1>

    <%# Flash messages %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-error">
        <% messages.forEach(function(message) { %>
          <p><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <%# Search and Filter widgets, side by side %>
    <div style="display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 260px;">
        <%- include('partials/searchBar', { search: search }) %>
      </div>
      <div style="flex: 2; min-width: 320px;">
        <%- include('partials/filterOnly', {
          categories: categories,
          storageOptions: storageOptions,
          selectedCategory: selectedCategory,
          selectedStorage: selectedStorage,
          selectedExpiry: selectedExpiry,
          selectedSort: selectedSort
        }) %>
      </div>
    </div>

    <%# Results %>
    <table class="pantry-table">
      <thead>
        <tr>
          <th>Ingredient</th>
          <th>Category</th>
          <th>Storage Location</th>
          <th>Quantity</th>
          <th>Unit</th>
          <th>Expiry Date</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr>
            <td colspan="7">No ingredients found matching your search/filter.</td>
          </tr>
        <% } else { %>
          <% items.forEach(function(item) { %>
            <tr>
              <td><%= item.ingredientName %></td>
              <td><%= item.category %></td>
              <td><%= item.storageLocation %></td>
              <td><%= item.quantity %></td>
              <td><%= item.unit %></td>
              <td><%= item.expiryDate ? new Date(item.expiryDate).toLocaleDateString() : 'Not set' %></td>
              <td>
                <% if (item.daysUntilExpiry < 0) { %>
                  <span class="badge badge-expired">🔴 Expired</span>
                <% } else if (item.daysUntilExpiry <= 3) { %>
                  <span class="badge badge-soon">🟡 Expiring Soon</span>
                <% } else { %>
                  <span class="badge badge-safe">🟢 Safe</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>

  </div>

</body>
</html>
