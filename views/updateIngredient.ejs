<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Update Ingredient</title>
</head>
<body>
  <!-- Navigation for managers -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Kitchen Inventory</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/inventory">Inventory</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Form used by managers to edit an existing ingredient record -->
  <div class="container mt-4">
    <h2 class="text-center mb-4">Update Ingredient</h2>
    <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
      <div class="alert alert-danger">
        <% errorMessages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <% if (product) { %>
      <form action="/updateProduct/<%= product.productId %>" method="POST" enctype="multipart/form-data" class="mx-auto" style="max-width: 600px;">

        <div class="mb-3">
          <label for="name" class="form-label">Ingredient Name</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= product.productName %>" required>
        </div>

        <div class="row">
          <div class="col-md-4 mb-3">
            <label for="quantity" class="form-label">Quantity</label>
            <input type="number" class="form-control" id="quantity" name="quantity" min="0" step="1" value="<%= product.quantity %>" required>
          </div>
          <div class="col-md-4 mb-3">
            <label for="unit" class="form-label">Unit</label>
            <input type="text" class="form-control" id="unit" name="unit" value="<%= product.unit || 'kg' %>">
          </div>
          <div class="col-md-4 mb-3">
            <label for="price" class="form-label">Price</label>
            <input type="number" class="form-control" id="price" name="price" min="0" step="0.01" value="<%= product.price %>" required>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="supplier" class="form-label">Supplier</label>
            <input type="text" class="form-control" id="supplier" name="supplier" value="<%= product.supplier || 'N/A' %>">
          </div>
          <div class="col-md-6 mb-3">
            <label for="category" class="form-label">Category</label>
            <input type="text" class="form-control" id="category" name="category" value="<%= product.category || 'General' %>">
          </div>
        </div>

        <div class="mb-3">
          <label for="expiryDate" class="form-label">Expiry Date</label>
          <input type="date" class="form-control" id="expiryDate" name="expiryDate" value="<%= product.expiryDate ? product.expiryDate.toISOString().slice(0,10) : '' %>">
        </div>

        <div class="mb-3">
          <label class="form-label">Current Image</label>
          <input type="text" class="form-control" name="currentImage" value="<%= product.image %>" readonly>
          <img src="/images/<%= product.image %>" class="img-thumbnail mt-2" style="width: 150px;">
        </div>

        <div class="mb-4">
          <label for="image" class="form-label">Upload New Image</label>
          <input class="form-control" type="file" id="image" name="image" accept="image/*">
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary">Update Ingredient</button>
          <a href="/inventory" class="btn btn-secondary">Back to Inventory</a>
        </div>
      </form>
    <% } else { %>
      <p class="text-center">No ingredient found.</p>
    <% } %>
  </div>
</body>
</html>
