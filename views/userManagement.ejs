<!DOCTYPE html>
<html>
<head>
    <title>User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="um-page">
        <h1>User management</h1>
        <p class="um-subtitle">Accounts lock automatically after 5 failed login attempts. Reactivate them below.</p>

        <% if (messages && messages.length > 0) { %>
            <div class="um-alert alert-danger">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>
        <% if (successMessages && successMessages.length > 0) { %>
            <div class="um-alert alert-success">
                <% successMessages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="um-card">
            <table class="um-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Failed attempts</th>
                        <th>Status</th>
                        <th style="text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% staffList.forEach(function(staff) { %>
                        <tr>
                            <td><%= staff.fullName %></td>
                            <td class="muted"><%= staff.email %></td>
                            <td><%= staff.role %></td>
                            <td class="muted"><%= staff.failedAttempts %></td>
                            <td>
                                <% if (staff.isLocked) { %>
                                    <span class="um-status locked"><span class="dot"></span>Locked</span>
                                <% } else { %>
                                    <span class="um-status active"><span class="dot"></span>Active</span>
                                <% } %>
                            </td>
                            <td style="text-align: right;">
                                <% if (staff.isLocked) { %>
                                    <form method="POST" action="/user-management/<%= staff.staffId %>/reactivate" onsubmit="return confirm('Reactivate this account?');">
                                        <button type="submit" class="um-reactivate">Reactivate</button>
                                    </form>
                                <% } else { %>
                                    <span class="um-dash">&mdash;</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
