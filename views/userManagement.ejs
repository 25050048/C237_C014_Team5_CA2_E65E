<!DOCTYPE html>
<html>
<head>
    <title>User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <style>
        .um-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }
        .um-card table {
            margin-bottom: 0;
        }
        .um-card thead th {
            border-top: none;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: #666;
            background: #f7f7f5;
        }
        .um-badge {
            border-radius: 999px;
            padding: 5px 14px;
            font-size: 0.78rem;
            font-weight: 500;
        }
        .um-btn {
            border-radius: 10px;
            font-weight: 500;
            padding: 6px 16px;
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container py-4">
        <h1 class="mb-1">User Management</h1>
        <p class="text-muted mb-4">Accounts lock automatically after 5 failed login attempts. Reactivate them below.</p>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-danger" style="border-radius: 10px;">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>
        <% if (successMessages && successMessages.length > 0) { %>
            <div class="alert alert-success" style="border-radius: 10px;">
                <% successMessages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="card um-card">
            <div class="card-body p-0">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Failed Attempts</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% staffList.forEach(function(staff) { %>
                            <tr>
                                <td><%= staff.fullName %></td>
                                <td><%= staff.email %></td>
                                <td><%= staff.role %></td>
                                <td><%= staff.failedAttempts %></td>
                                <td>
                                    <% if (staff.isLocked) { %>
                                        <span class="badge bg-danger um-badge">Locked</span>
                                    <% } else { %>
                                        <span class="badge bg-success um-badge">Active</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <% if (staff.isLocked) { %>
                                        <form method="POST" action="/user-management/<%= staff.staffId %>/reactivate" onsubmit="return confirm('Reactivate this account?');">
                                            <button type="submit" class="btn btn-dark btn-sm um-btn">Reactivate</button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-muted">&mdash;</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
